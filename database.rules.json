{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "profile": {
          ".validate": "newData.hasChildren(['updatedAt']) || !newData.exists()"
        },
        "stats": {
          ".validate": "!newData.exists() || newData.hasChildren()"
        },
        "matches": {
          "$matchId": {
            ".validate": "!newData.exists() || newData.hasChildren(['result', 'sport', 'rounds', 'date'])"
          }
        },
        "dailyStreak": {
          ".validate": "!newData.exists() || newData.hasChildren(['current', 'best', 'lastPlayedDateKey', 'updatedAt'])"
        },
        "playActivity": {
          "$dateKey": {
            "$source": {
              ".validate": "!newData.exists() || newData.hasChildren(['dateKey', 'source', 'playedAt'])"
            }
          }
        },
        "notifications": {
          "streakReminder": {
            ".validate": "!newData.exists() || newData.hasChildren(['lastSentDateKey'])"
          },
          "streakLost": {
            ".validate": "!newData.exists() || newData.hasChildren(['lastSentDateKey'])"
          }
        },
        "pushSubscriptions": {
          "$subscriptionId": {
            ".validate": "!newData.exists() || newData.hasChildren(['endpoint', 'keys', 'createdAt'])"
          }
        }
      }
    },
    "rooms": {
      ".read": true,
      ".write": true,
      "$roomId": {
        ".validate": "newData.hasChildren(['code', 'sport', 'rounds', 'status'])"
      }
    },
    "teamRooms": {
      ".read": true,
      ".write": true,
      "$roomId": {
        ".validate": "newData.hasChildren(['code', 'sport', 'rounds', 'status'])"
      }
    },
    "invites": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "dailyLeaderboards": {
      ".read": true,
      ".write": false,
      "$dateKey": {
        "$sport": {
          "entries": {
            ".write": true,
            ".validate": "newData.hasChildren(['playerId', 'displayName', 'score', 'totalQuestions', 'totalTimeMs', 'accuracyPct', 'updatedAt'])",
            "$playerId": {
              ".validate": "newData.child('playerId').val() === $playerId && newData.child('score').isNumber() && newData.child('score').val() >= 0 && newData.child('score').val() <= newData.child('totalQuestions').val() && newData.child('totalTimeMs').isNumber() && newData.child('totalTimeMs').val() >= 0"
            }
          }
        }
      }
    }
  }
}