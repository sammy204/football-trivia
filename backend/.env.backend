# Push Notification Server Configuration

# VAPID Keys (generate with: web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=<your_public_key_here>
VAPID_PRIVATE_KEY=<your_private_key_here>
VAPID_EMAIL=admin@footballtrivia.com

# Server Configuration
PORT=3001
NODE_ENV=production

# Database Connection (optional for persistence)
# DATABASE_URL=
