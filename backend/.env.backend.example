# Push Notification Server Configuration
VAPID_PUBLIC_KEY=<your_dev_vapid_public_key>
VAPID_PRIVATE_KEY=<your_dev_vapid_private_key>
VAPID_EMAIL=mailto:you@example.com

# Local backend server
PORT=3001
NODE_ENV=development
ENABLE_TEST_ROUTES=true

# Use a separate Firebase project for local/dev testing when possible
FIREBASE_DATABASE_URL=<your_dev_realtime_database_url>
# FIREBASE_SERVICE_ACCOUNT_PATH=C:\path\to\serviceAccountKey.json
